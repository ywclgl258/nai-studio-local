# ========================================
# NAI Studio - Git Ignore
# ========================================
# 上传时**只**包含源代码、schema、配置、文档。
# 不上传：运行时数据、生成的图、缓存、日志、本地配置。

# === 运行时数据（绝对不要上传）===
# 用户生成的所有图、缩略图、上传文件
public/storage/images/
public/storage/thumbs/
public/storage/uploads/
public/storage/logs/

# API 响应 / 导入状态 / 临时缓存
public/storage/cache/
!public/storage/cache/.gitkeep

# 运行时日志（PHP / Apache error log）
logs/
storage/logs/

# 截图（本地开发用，不进版本库）
storage/screenshots/

# 标签预览图（856+ 个 JPEG，体积大，运行时按需生成）
storage/tag-previews/

# SQLite 数据库文件（含用户加密 API key + 全部运行时数据）
# schema 在 data/schema_sqlite.sql 跟踪，DB 文件不进版本库
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db.old-*
# 备份（mysqldump / 自动备份产物）
data/backups/

# === 敏感信息（防御性）===
.env
.env.local
*.pem
*.key
api_key*.txt
secret*.json
secrets/

# === 临时 / 测试文件 ===
tests/tmp/
tests/cache/
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db

# === 编辑器 / IDE ===
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# === Node / 构建产物（保留供未来扩展）===
node_modules/
dist/
build/
*.log
npm-debug.log*

# === Windows 特定 ===
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# === Git 自身 ===
.git/
.gitignore